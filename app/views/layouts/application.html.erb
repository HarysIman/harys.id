<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <title><%= content_for?(:title) ? yield(:title) : seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:description) ? seo_description(yield(:description)) : seo_description %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Harys.id">
    <meta name="mobile-web-app-capable" content="yes">

    <%# Canonical %>
    <link rel="canonical" href="<%= content_for?(:canonical) ? yield(:canonical) : canonical_url %>">

    <%# Open Graph %>
    <meta property="og:site_name" content="Harys Imanulloh">
    <meta property="og:locale"    content="id_ID">
    <meta property="og:type"      content="<%= content_for?(:og_type) ? yield(:og_type) : "website" %>">
    <meta property="og:title"     content="<%= content_for?(:title) ? yield(:title) : seo_title %>">
    <meta property="og:description" content="<%= content_for?(:description) ? seo_description(yield(:description)) : seo_description %>">
    <meta property="og:url"       content="<%= content_for?(:canonical) ? yield(:canonical) : canonical_url %>">
    <meta property="og:image"     content="<%= content_for?(:og_image) ? yield(:og_image) : ApplicationHelper::DEFAULT_OG_IMAGE %>">

    <%# Twitter Card %>
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="<%= content_for?(:title) ? yield(:title) : seo_title %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? seo_description(yield(:description)) : seo_description %>">
    <meta name="twitter:image"       content="<%= content_for?(:og_image) ? yield(:og_image) : ApplicationHelper::DEFAULT_OG_IMAGE %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;700;800;900&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet" />

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/nav" %>
    <%= yield %>
  </body>
</html>
